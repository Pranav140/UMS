{
  "name": "pern-backend",
  "version": "1.0.0",
  "description": "UMS Backend — Express + Prisma + PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format cjs --dts",
    "start": "node dist/server.js",
    "seed": "tsx prisma/seed.ts",
