generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  FACULTY
  ADMIN
  DEVELOPER
}

enum CourseType {
  THEORY
  THEORY_LAB
  LAB
  PROJECT
}

enum CourseCategory {
  MAJOR
  MINOR
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  Session[]
  auditLogs AuditLog[]

  studentProfile StudentProfile?
  facultyProfile FacultyProfile?
  enrollments    Enrollment[]
  attendances    Attendance[]
  grades         Grade[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// === Degrees ===

model Degree {
  id          String   @id @default(uuid())
  code        String   @unique  // Branch code (CSE, ECE, IT, etc.)
  name        String             // Full name (Computer Science & Engineering, etc.)
  description String?
  isMajor     Boolean  @default(true)  // true for major degrees, false for minor degrees
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  studentProfiles StudentProfile[]
}

// === Phase 2 ===

model Course {
  id          String         @id @default(uuid())
  code        String         @unique
  title       String
  description String?
  credits     Int
  theoryCredits Int?
  labCredits    Int?
  type        CourseType     @default(THEORY) // THEORY for theory-only, THEORY_LAB for courses with lab component
  category    CourseCategory @default(MAJOR)  // MAJOR or MINOR course classification
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  sections Section[]
}

model Semester {
  id        String   @id @default(uuid())
  name      String   // e.g. "Spring 2026"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  
  sections Section[]
}

model Section {
  id         String   @id @default(uuid())
  courseId   String
  semesterId String
  sectionCode String  // Unique identifier for the section group (e.g., "A", "B", "C", or "Group1", "Group2")
  capacity   Int
  
  course   Course   @relation(fields: [courseId], references: [id])
  semester Semester @relation(fields: [semesterId], references: [id])
  
  facultyId String?
  faculty   FacultyProfile? @relation(fields: [facultyId], references: [id])

  enrollments Enrollment[]
  attendances Attendance[]
  grades      Grade[]
}

model StudentProfile {
  id             String @id @default(uuid())
  userId         String @unique
  enrollmentYear Int
  degreeId       String
  major          String  // Branch code (CSE, ECE, IT, etc.)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  degree Degree  @relation(fields: [degreeId], references: [id], onDelete: Restrict)
}

model FacultyProfile {
  id         String @id @default(uuid())
  userId     String @unique
  department String
  title      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectionsTeaching Section[]
}

model Enrollment {
  id        String   @id @default(uuid())
  studentId String
  sectionId String
  status    String   @default("ENROLLED") // ENROLLED, DROPPED
  createdAt DateTime @default(now())

  student User    @relation(fields: [studentId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@unique([studentId, sectionId])
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  sectionId String
  date      DateTime
  isPresent Boolean
  createdAt DateTime @default(now())

  student User    @relation(fields: [studentId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@unique([studentId, sectionId, date])
}

model Grade {
  id        String   @id @default(uuid())
  studentId String
  sectionId String
  
  // Score tracking - differentiated by course type
  
  // A. Theory Rubrics (max 100 sum)
  theoryCa Float?   // Continuous assessment (max 20)
  theoryMt Float?   // Mid-Term (max 30)
  theoryEs Float?   // End Semester (max 50)
  
  // B. Lab Rubrics (max 100 sum)
  labCa Float?      // Continuous assessment (max 40)
  labFr Float?      // Lab File/Record (max 10)
  labEs Float?      // End Semester/Viva (max 50)
  
  // C. Project Rubrics (max 100 sum)
  projectCa Float?  // Continuous Assessment by Supervisor (max 20)
  projectMr Float?  // Mid Semester Review (max 40)
  projectEs Float?  // Final project viva-voce (max 40)

  score     Float?  // Final calculated composite score (0-100)
  
  letter    String?   // A, B, C, etc.
  status    String    @default("DRAFT") // DRAFT, FINALIZED
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  student User    @relation(fields: [studentId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@unique([studentId, sectionId])
}
