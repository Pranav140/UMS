# PostgreSQL — matches docker-compose.yml credentials
DATABASE_URL="postgresql://umsuser:umspassword@localhost:5432/umsdb"

# JWT & Cookie secrets
JWT_SECRET="ums_jwt_secret_change_in_production"
COOKIE_SECRET="ums_cookie_secret_change_in_production"

# MinIO / S3 — matches docker-compose.yml credentials
MINIO_ENDPOINT="http://localhost:9000"
MINIO_ACCESS_KEY="miniouser"
MINIO_SECRET_KEY="miniopassword123"
MINIO_BUCKET="ums-storage"

# Environment
NODE_ENV="development"
